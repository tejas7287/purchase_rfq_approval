<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="mail_template_po_submit_approval" model="mail.template">
            <field name="name">RFQ Submitted for Approval</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="subject">RFQ Approval - {{ object.name or 'Unknown RFQ' }}</field>
            <field name="email_from">{{ (object.user_id.email_formatted or object.company_id.email_formatted or user.email_formatted) }}</field>
            <field name="partner_to" eval="False"/>
            <field name="use_default_to" eval="True"/>
            <field name="description">Used by PR Request when they send RFQ to prospects</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        <t t-set="doc_name" t-value="'quotation' if object.state in ('draft', 'sent') else 'order'"/>
                        Hello,
                        <br/>
                        <br/>
                        Your PR request for
                        <t t-out="doc_name or ''">quotation</t>
                        <span style="font-weight: bold;" t-out="object.name or ''">PR0001</span>
                        <t t-if="object.origin">
                            (with reference Vendor: <t t-out="object.partner_id.name or ''"></t> )
                        </t>
                        amounting in <span style="font-weight: bold;"
                                           t-out="format_amount(object.amount_total, object.currency_id) or ''">$ 10.00
                    </span> is available.
                        <br/>
                        <br/>
                        Do not hesitate to contact us if you have any questions.
                        <t t-if="not is_html_empty(object.user_id.signature)">
                            <div>--
                                <br/>
                                <t t-out="object.user_id.signature or ''">Mitchell Admin</t>
                            </div>
                        </t>
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>

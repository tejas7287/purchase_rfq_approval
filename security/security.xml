<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- 1. Define the Category as usual -->
        <record id="module_category_purchase_approval" model="ir.module.category">
            <field name="name">Purchase Approval Management</field>
            <field name="sequence">10</field>
        </record>

        <!-- 2. Define a Privilege (New for Odoo 19) -->
        <record id="res_groups_privilege_purchase_approval" model="res.groups.privilege">
            <field name="name">Purchase Approvals</field>
            <field name="category_id" ref="purchase_rfq_approval.module_category_purchase_approval"/>
        </record>

        <!-- 3. Define the Group using privilege_id instead of category_id -->
        <record id="group_purchase_approver" model="res.groups">
            <field name="name">Purchase Approver</field>
            <!-- Use the new privilege_id field -->
            <field name="privilege_id" ref="purchase_rfq_approval.res_groups_privilege_purchase_approval"/>
            <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_user'))]"/>
        </record>
    </data>
</odoo>

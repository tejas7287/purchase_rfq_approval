<odoo>
    <!-- 1. Action: Changed view_mode from 'tree,form' to 'list,form' -->
    <record id="action_purchase_approval_team" model="ir.actions.act_window">
        <field name="name">Approval Teams</field>
        <field name="res_model">purchase.approval.team</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- 2. List View (Formerly Tree) -->
    <record id="view_purchase_approval_team_list" model="ir.ui.view">
        <field name="name">purchase.approval.team.list</field>
        <field name="model">purchase.approval.team</field>
        <field name="arch" type="xml">
            <list string="Approval Teams">
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- 3. Form View -->
    <record id="view_purchase_approval_team_form" model="ir.ui.view">
        <field name="name">purchase.approval.team.form</field>
        <field name="model">purchase.approval.team</field>
        <field name="arch" type="xml">
            <form string="Approval Team">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Finance Approval Team"/>
                        </h1>
                    </div>
                    <group>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <notebook>
                        <page string="Approval Rules" name="approval_rules">
                            <field name="rule_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="min_amount"/>
                                    <field name="max_amount"/>
                                    <field name="approver_ids" widget="many2many_tags" options="{'no_create': True}"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
